# Server-side variables for api/generate-quest.js
# Copy to api/.env.local and fill in secrets for local testing.

# Supports either OpenAI key or Codex API key.
OPENAI_API_KEY=
CODEX_API_KEY=

# Optional model/url overrides for non-default backends.
AI_MODEL=gpt-4.1-mini
AI_RESPONSES_URL=https://api.openai.com/v1/responses
